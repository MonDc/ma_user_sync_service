# ====================================================
# [OUTBOUND CONNECTION] 
# MA USER SYNC SERVICE - ENVIRONMENT CONFIGURATION
# ====================================================
# Your app only needs to know where to find OTHER things,
# not its own address. That's why this .env is only about
# OUTBOUND CONNECTIONS to databases and external services.
#
# NEVER commit this file to version control!
# Copy .env.example to .env and fill in your values.


# [NO SSH, it is TCP connection directly to MySQL port 3306 on the DB server, so no need for SSH credentials here]
# [My Go app opens TCP connection to 192.168.178.22:3306]
# [My MA Go app's .env file contains only what the app needs to connect OUT to other services.]
# ====================================================

SQL_SERVER_22=192.***.***.**    # DB server IP
SQL_SERVER_22_PORT=3306
SQL_SERVER_22_DB_USER=user***
SQL_SERVER_22_DB_PASS=pass***

# Database names for MI and MA services
MI=**
MA=**